# Firestore Send Email Extension Configuration

# Email documents collection name
MAIL_COLLECTION=mail

# SMTP connection - Using Gmail as example
# You can use Gmail, SendGrid, or any SMTP service
SMTP_CONNECTION_URI=smtps://username@gmail.com@smtp.gmail.com:465

# Gmail App Password (not regular password)
# Get app password from: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=your-app-password-here

# Default FROM address
DEFAULT_FROM=Gallery App <noreply@galleryapp.com>

# Default REPLY-TO address (optional)
DEFAULT_REPLY_TO=support@galleryapp.com

# Users collection (optional)
USERS_COLLECTION=users

# Email templates (optional - for Handlebars templates)
TEMPLATES_COLLECTION=email_templates